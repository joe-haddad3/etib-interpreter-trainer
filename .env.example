# ============================================================
# ETIB Interpreter Training Platform — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# --- FREE LLM APIs (get these first) ---

# Groq (free tier — Llama 3.1 70B)
# Sign up at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Google AI Studio (free tier — Gemini 1.5 Flash)
# Sign up at: https://aistudio.google.com
GOOGLE_AI_KEY=your_google_ai_key_here

# --- LLM PROVIDER ---
# Use groq, local_aya, or remote_aya.
LLM_PROVIDER=groq
LOCAL_MODEL_ID=CohereLabs/aya-expanse-8b
# Example Windows path after manual download:
# LOCAL_MODEL_PATH=C:\Users\user\Desktop\ETIB-Interpreter-Trainer\models\aya-expanse-8b
LOCAL_MODEL_PATH=
LOCAL_MODEL_DEVICE_MAP=auto
LOCAL_MODEL_TORCH_DTYPE=auto
# Example Colab/ngrok endpoint for remote Aya:
# REMOTE_AYA_URL=https://abc123.ngrok-free.app/generate
REMOTE_AYA_URL=
REMOTE_AYA_TIMEOUT_SECONDS=300
# Set to false only for local development if ngrok/Colab gives a certificate error.
REMOTE_AYA_VERIFY_SSL=true

# --- OPTIONAL PAID FALLBACKS ---
# Only add these if free tier is insufficient after testing

OPENAI_API_KEY=
ELEVENLABS_API_KEY=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# --- APP CONFIG ---
FLASK_SECRET_KEY=change_this_to_a_random_string_in_production
FLASK_ENV=development
FLASK_DEBUG=true

# --- FILE PATHS ---
UPLOAD_FOLDER=./uploads
AUDIO_OUTPUT_FOLDER=./audio_outputs

# --- DATABASE ---
# MongoDB local development
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=etib_interpreter_trainer

# Copy this to .env and fill in your values (never commit .env)

LLM_PROVIDER=groq
GROQ_API_KEY=gsk_your_key_here
GOOGLE_AI_KEY=your_google_ai_key_here

FLASK_SECRET_KEY=change-this-to-a-random-string
FLASK_ENV=production
FLASK_DEBUG=false

MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/etib_interpreter_trainer
MONGODB_DB=etib_interpreter_trainer

# Paste your Vercel frontend URL here (no trailing slash)
ALLOWED_ORIGINS=https://your-app.vercel.app

UPLOAD_FOLDER=./uploads
AUDIO_OUTPUT_FOLDER=./audio_outputs
